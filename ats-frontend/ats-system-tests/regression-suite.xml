<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="CVortex ATS Regression Suite" parallel="false" verbose="1">
    <listeners>
        <listener class-name="com.cvortex.ats.listeners.TestListener"/>
        <listener class-name="com.cvortex.ats.retry.RetryTransformer"/>
    </listeners>
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="com.cvortex.ats.tests.*"/>
        </packages>
    </test>
</suite>
